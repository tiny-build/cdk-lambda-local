{
  "name": "simple-crud-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "synth": "AWS_ENDPOINT_URL=http://localhost:4566 cdk synth --app 'tsx cdk/app.ts'",
    "extract": "cdk-local extract --cdk-out cdk.out --stack SimpleCrudStack --stage dev --repo-root ../.. --out .cdk-local/manifest.json",
    "manifest": "pnpm run synth && pnpm run extract",
    "serve": "cdk-local serve --manifest .cdk-local/manifest.json --port 3001 --watch",
    "dev": "pnpm run manifest && pnpm run serve",
    "init": "pnpm cdk-local init",
    "seed": "./scripts/seed.sh"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1037.0",
    "@aws-sdk/client-s3": "^3.1037.0",
    "cdk-local-lambda": "workspace:*",
    "aws-cdk-lib": "^2.251.0",
    "constructs": "^10.6.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.6.0",
    "aws-cdk": "^2.1119.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}