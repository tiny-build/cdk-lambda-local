{
	"name": "aws-cdk-local-lambda",
	"root": "packages/aws-cdk-local-lambda",
	"sourceRoot": "packages/aws-cdk-local-lambda/src",
	"targets": {
		"build": {
			"command": "pnpm exec tsup",
			"options": {
				"cwd": "packages/aws-cdk-local-lambda"
			},
			"outputs": [
				"{projectRoot}/dist"
			]
		},
		"format": {
			"command": "biome format \"src/**/*.ts\"",
			"options": {
				"cwd": "packages/aws-cdk-local-lambda"
			}
		},
		"format:fix": {
			"command": "biome format --write \"src/**/*.ts\"",
			"options": {
				"cwd": "packages/aws-cdk-local-lambda"
			}
		},
		"test": {
			"command": "pnpm test",
			"options": {
				"cwd": "packages/aws-cdk-local-lambda"
			}
		}
	}
}