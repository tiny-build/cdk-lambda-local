{
  "name": "aws-cdk-local-lambda",
  "version": "1.0.0",
  "license": "MIT",
  "description": "Run an API Gateway + Lambda app locally over HTTP, driven entirely by cdk synth output.",
  "type": "module",
  "bin": {
    "cdk-local": "./dist/bin/cdk-local.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./extract": {
      "source": "./src/extract/index.ts",
      "import": {
        "types": "./dist/extract/index.d.ts",
        "default": "./dist/extract/index.js"
      },
      "require": {
        "types": "./dist/extract/index.d.ts",
        "default": "./dist/extract/index.cjs"
      }
    },
    "./server": {
      "source": "./src/server/index.ts",
      "import": {
        "types": "./dist/server/index.d.ts",
        "default": "./dist/server/index.js"
      },
      "require": {
        "types": "./dist/server/index.d.ts",
        "default": "./dist/server/index.cjs"
      }
    },
    "./types": {
      "source": "./src/types.ts",
      "import": {
        "types": "./dist/types.d.ts",
        "default": "./dist/types.js"
      },
      "require": {
        "types": "./dist/types.d.ts",
        "default": "./dist/types.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "readme_assets"
  ],
  "scripts": {
    "build": "tsup && pnpm run build:types",
    "build:types": "tsc -p tsconfig.dts.json",
    "dev": "tsup --watch",
    "prepare": "pnpm run build",
    "test": "vitest run",
    "format:fix": "biome format --write \"src/**/*.ts\""
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "esbuild": "^0.28.0",
    "express": "^5.2.1",
    "tinyglobby": "0.2.16"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@types/aws-lambda": "^8.10.0"
  },
  "engines": {
    "node": ">=22.14"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "url": "https://github.com/tiny-build/aws-cdk-local-lambda"
  }
}