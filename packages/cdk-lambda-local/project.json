{
	"name": "cdk-lambda-local",
	"root": "packages/cdk-lambda-local",
	"sourceRoot": "packages/cdk-lambda-local/src",
	"targets": {
		"build": {
			"command": "pnpm exec tsup",
			"options": {
				"cwd": "packages/cdk-lambda-local"
			},
			"outputs": [
				"{projectRoot}/dist"
			]
		},
		"format": {
			"command": "biome format \"src/**/*.ts\"",
			"options": {
				"cwd": "packages/cdk-lambda-local"
			}
		},
		"format:fix": {
			"command": "biome format --write \"src/**/*.ts\"",
			"options": {
				"cwd": "packages/cdk-lambda-local"
			}
		}
	}
}