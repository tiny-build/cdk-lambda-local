{
	"name": "cdk-local-lambda",
	"root": "packages/cdk-local-lambda",
	"sourceRoot": "packages/cdk-local-lambda/src",
	"targets": {
		"build": {
			"command": "pnpm exec tsup",
			"options": { "cwd": "packages/cdk-local-lambda" },
			"outputs": ["{projectRoot}/dist"]
		},
		"format": {
			"command": "biome format \"src/**/*.ts\"",
			"options": { "cwd": "packages/cdk-local-lambda" }
		},
		"format:fix": {
			"command": "biome format --write \"src/**/*.ts\"",
			"options": { "cwd": "packages/cdk-local-lambda" }
		}
	}
}
