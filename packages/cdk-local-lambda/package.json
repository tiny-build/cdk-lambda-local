{
	"name": "@tiny-build/cdk-local-lambda",
	"version": "0.0.0",
	"private": true,
	"description": "Run an API Gateway + Lambda app locally over HTTP, driven entirely by cdk synth output.",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"source": "./src/index.ts",
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./extract": {
			"source": "./src/extract/index.ts",
			"import": {
				"types": "./dist/extract/index.d.ts",
				"default": "./dist/extract/index.js"
			},
			"require": {
				"types": "./dist/extract/index.d.cts",
				"default": "./dist/extract/index.cjs"
			}
		},
		"./server": {
			"source": "./src/server/index.ts",
			"import": {
				"types": "./dist/server/index.d.ts",
				"default": "./dist/server/index.js"
			},
			"require": {
				"types": "./dist/server/index.d.cts",
				"default": "./dist/server/index.cjs"
			}
		},
		"./types": {
			"source": "./src/types.ts",
			"import": {
				"types": "./dist/types.d.ts",
				"default": "./dist/types.js"
			},
			"require": {
				"types": "./dist/types.d.cts",
				"default": "./dist/types.cjs"
			}
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"format:fix": "oxfmt --write \"src/**/*.ts\""
	},
	"dependencies": {
		"esbuild": "^0.25.0",
		"chokidar": "^4.0.3",
		"commander": "^12.1.0",
		"cors": "^2.8.6",
		"express": "^5.2.1"
	},
	"devDependencies": {
		"@types/aws-lambda": "^8.10.147",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/node": "^22.13.5",
		"@types/supertest": "^6.0.2",
		"supertest": "^7.0.0",
		"tsup": "^8.3.5",
		"typescript": "^5.7.3",
		"vitest": "^2.1.9"
	},
	"peerDependencies": {
		"@types/aws-lambda": "^8.10.0"
	},
	"engines": {
		"node": ">=22.14"
	}
}
